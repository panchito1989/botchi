# Botchi web platform — environment variables
# Supabase project: "Botchi" (sjfdrbavqfntsqtquooo)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# APIs de paga que usan los endpoints públicos. Sin ellas el sitio no se
# rompe: el demo responde con un mensaje de espera y la voz cae a la del
# navegador.
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=   # default: voz "Sarah"
# ELEVENLABS_MODEL=      # default: eleven_multilingual_v2

# --- Rate limiting (aplicar antes: web/sql/rate_limit.sql) -----------
# Orígenes extra permitidos en /api/demo, /api/tts y /api/reservar, además
# del propio host de la petición. Coma-separados. Solo hace falta cuando el
# dominio público difiere del de la app (ej. botchi.mx vs *.vercel.app).
# ALLOWED_ORIGINS=https://botchi.mx,https://www.botchi.mx
# NEXT_PUBLIC_SITE_URL=https://botchi.mx

# Topes diarios. Los de por-IP frenan al abusador; los globales son el
# freno de mano si alguien rota IPs. Valores = defaults del código.
# DEMO_DAILY_PER_IP=200
# DEMO_DAILY_GLOBAL=3000
# TTS_DAILY_PER_IP=60
# TTS_DAILY_GLOBAL=1000

# Future monetization (Stripe) — not used yet, leave blank.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
