# Botchi — configuración del dispositivo.
# Copia este archivo a /home/botchi/botchi/botchi.env y rellena la llave.
#   cp botchi.env.example botchi.env && nano botchi.env
# Lo leen TANTO el servicio systemd COMO botchi.py directamente, así que
# `python3 botchi.py` toma la llave de aquí aunque lo lances por `ssh` de
# una línea (que no carga ~/.bashrc). Lo que ya esté en el entorno gana.
# IMPORTANTE: tras editarlo, dale `chmod 600 botchi.env` para que solo tu
# usuario lo lea (contiene secretos).

# Llave de Gemini (la del proyecto que ya funciona).
GEMINI_API_KEY=AIza-pega-tu-llave-aqui

# Wake word (di «Botchi» para despertarlo, como Alexa). 0 = modo ENTER.
# OJO: déjalo en 0 hasta mejorar el micrófono. El INMP441 capta muy flojo
# y el wake word NO detecta bien la palabra con esa señal — Botchi
# parecería "no oírte". El modo ENTER (aprieta ENTER para hablar) es el
# confiable por ahora.
BOTCHI_WAKEWORD=0

# Palabra mágica (en minúsculas; debe coincidir con lo que Vosk transcriba).
BOTCHI_WAKE_WORD=botchi

# Ruta al modelo de Vosk (descargado y descomprimido).
BOTCHI_VOSK_MODEL=/home/botchi/botchi/vosk-model

# Tope máximo (segundos) para la instrucción tras la palabra mágica.
BOTCHI_WAKE_MAX_INSTRUC=15

# Dispositivo de audio ALSA (no cambiar a menos que sepas).
BOTCHI_ALSA_DEV=plughw:0,0

# Ganancia del micrófono (INMP441 entrega bajo; sube si te escucha poco).
BOTCHI_MIC_GAIN=8
